{"source_id": "FULLRAG_HR::docs::onboarding_policy", "source_type": "doc", "title": "员工入职权限政策", "language": "zh", "access_level": "public", "product_area": "full_rag_heldout", "tags": ["full-rag-heldout", "fullrag_hr_policy_cn"], "canonical_url": "", "metadata": {"provider": "full_rag_heldout_fixture", "fixture_id": "fullrag_hr_policy_cn"}, "sections": [{"section_id": "access_approval", "title": "入职权限审批", "text": "入职权限审批流程：候选人签署 offer 后，HR 在 HR Portal > Onboarding 创建入职记录。直属 manager 审批岗位、成本中心和系统权限范围。审批完成后，IT 权限工单会自动创建，IT service desk 在员工入职日前一天完成账号和设备准备。", "metadata": {}}]}
