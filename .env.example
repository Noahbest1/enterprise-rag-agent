# Copy to .env.local for dev. Docker Compose reads these via its own
# `environment:` section -- only put here what you want pydantic-settings
# to pick up when running locally outside Docker.

# ── Runtime environment ─────────────────────────────────────────
# env: dev | staging | prod | test
ENV=dev
# log_level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# log_format: console (pretty) | json (prod-friendly)
LOG_FORMAT=console

# ── LLM (Qwen / DashScope) ──────────────────────────────────────
# Required for query rewrite + answer generation.
DASHSCOPE_API_KEY=
COPILOT_QWEN_MODEL=qwen-plus
COPILOT_QWEN_CHAT_COMPLETIONS_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# ── API service ────────────────────────────────────────────────
COPILOT_API_HOST=127.0.0.1
COPILOT_API_PORT=8008
COPILOT_CORS_ALLOW_ORIGINS=http://127.0.0.1:5714,http://localhost:5714

# ── Feature flags ──────────────────────────────────────────────
ENABLE_QUERY_REWRITE=true
ENABLE_MULTI_QUERY_DEFAULT=false

# ── Retrieval tuning ──────────────────────────────────────────
BM25_TOP_K=40
VECTOR_TOP_K=40
RRF_K=60
RERANK_TOP_K=8
FINAL_TOP_K=5
ABSTAIN_SCORE_THRESHOLD=0.15

# ── Chunking ──────────────────────────────────────────────────
CHUNK_TARGET_TOKENS=450
CHUNK_OVERLAP_TOKENS=80

# ── Data services (used when ENV != 'test') ──────────────────
# Local dev defaults; Docker Compose overrides to the service-name hosts.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql+psycopg://rag:rag@localhost:5432/rag

# ── Rate limiting ──────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Frontend ───────────────────────────────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8008
